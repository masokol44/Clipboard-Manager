using System;

class Program
{
    static void Main()
    {
        string[] clipboard =
        {
            "First text",
            "Second text",
            "Third text"
        };

        Console.WriteLine("Clipboard History:");

        for (int i = 0; i < clipboard.Length; i++)
        {
            Console.WriteLine(
                $"{i + 1}: {clipboard[i]}"
            );
        }
    }
}
